{
  "image": "ghcr.io/bootc-dev/devenv-debian",
  "postCreateCommand": {
    "write-adc": "if [ -n \"$GOOGLE_ADC_JSON\" ]; then mkdir -p ~/.config/gcloud && printf '%s' \"$GOOGLE_ADC_JSON\" > ~/.config/gcloud/application_default_credentials.json; fi"
  },
  "customizations": {
    "devaipod": {
      "nestedContainers": true
    }
  },
  "runArgs": ["--privileged"]
}
